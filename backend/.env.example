NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:5173
NEXT_PUBLIC_APP_URL=http://localhost:5173
DATABASE_URL=postgresql://review_intel_user:review_intel_password@localhost:5432/review_intel_care?schema=public
AUTH_SESSION_SECRET=replace-with-a-long-random-session-secret-at-least-32-characters

# Google Cloud OAuth client for Google Business Profile APIs.
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback

# Places API key. Keep this server-side only.
GOOGLE_PLACES_API_KEY=your-google-places-api-key

# Stripe Billing.
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_local_or_live_webhook_secret
STRIPE_PRICE_PREMIUM_MONTHLY=price_your_20_monthly_premium_price_id
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_BILLING_PORTAL_RETURN_URL=http://localhost:5173

# Comma-separated OAuth scopes.
GOOGLE_OAUTH_SCOPES=https://www.googleapis.com/auth/business.manage

# Optional production controls.
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=300
